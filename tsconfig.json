{
  "compilerOptions": {
    "target": "ES2021",
    "module": "commonjs",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "typeRoots": [
      "./node_modules/@types",
      "../OpenSearch-Dashboards/node_modules/@types"
    ],
    "types": ["node"],
    "skipLibCheck": true,
    "outDir": "build"
  },
  "include": ["index.ts", "server/**/*", "public/**/*"]
}
